{
  "entities": {
    "ConceptNode": {
      "title": "ConceptNode",
      "description": "A public shared node in the Marananusmrti research corpus.",
      "type": "object",
      "properties": {
        "node_id": {
          "type": "string"
        },
        "concept_title": {
          "type": "string"
        },
        "grouping_category": {
          "type": "string"
        },
        "keywords": {
          "type": "array"
        },
        "text_fragments": {
          "type": "array"
        },
        "suggested_sub_concepts": {
          "type": "array"
        },
        "parentId": {
          "type": "string"
        },
        "origin": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "sourceNodeId": {
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "concept_title",
        "grouping_category",
        "keywords",
        "text_fragments",
        "suggested_sub_concepts",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "public_nodes/{nodeId}": {
      "schema": "ConceptNode",
      "description": "Flat public collection of philosophical concept nodes, keyed by node_id."
    }
  }
}
